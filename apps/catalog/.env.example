# Catalog contact handles — PUBLIC contact identifiers, NOT secrets.
# These are the same handles printed on the storefront's contact buttons; safe
# to commit a copy here as an example. Read ONLY by lib/contact-env.ts (server).
#
# If a value is left blank, that channel's button simply does not render — the
# storefront degrades gracefully (no broken links, no crash).

# Full LINE URL, e.g. https://line.me/R/ti/p/@wnlq9
LINE_OFFICIAL_URL=

# WhatsApp number: digits only, with country code, no '+' (e.g. 66812345678)
WHATSAPP_NUMBER=

# Facebook Messenger page handle only (the part after m.me/), e.g. wnlq9
FB_MESSENGER_PAGE=
